{
  "color": {
    "$type": "color",
    "surface": {
      "default": { "$value": "{color.gray.50}" },
      "raised":  { "$value": "{color.white}" }
    },
    "text": {
      "primary": { "$value": "{color.gray.900}" },
      "inverse": { "$value": "{color.white}" }
    },
    "action": {
      "primary":       { "$value": "{color.blue.600}" },
      "primary-hover": { "$value": "{color.blue.700}" }
    },
    "danger": {
      "default": { "$value": "{color.red.600}" }
    }
  }
}