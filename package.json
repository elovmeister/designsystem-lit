{
  "name": "design-system",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",

    "dev": "turbo run dev --parallel --filter=./packages/*",
    "storybook": "turbo run dev storybook --parallel --filter=@ds/components...",
    "dev:react": "turbo run dev --parallel --filter=@ds/test-react...",
    "dev:angular": "turbo run dev --parallel --filter=@ds/test-angular...",

    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0"
}